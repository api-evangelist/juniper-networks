{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/AsnPool",
  "title": "AsnPool",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "display_name": {
      "type": "string"
    },
    "ranges": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "first": {
            "type": "integer",
            "description": "First ASN in the range."
          },
          "last": {
            "type": "integer",
            "description": "Last ASN in the range."
          }
        }
      }
    },
    "status": {
      "type": "string",
      "description": "Pool usage status."
    }
  }
}