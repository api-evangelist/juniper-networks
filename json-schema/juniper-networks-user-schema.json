{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/User",
  "title": "User",
  "type": "object",
  "properties": {
    "@key": {
      "type": "integer",
      "description": "User internal ID."
    },
    "name": {
      "type": "string",
      "description": "Username."
    },
    "firstName": {
      "type": "string"
    },
    "lastName": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "status": {
      "type": "string",
      "enum": [
        "Active",
        "Disabled"
      ]
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Assigned role names."
    }
  }
}